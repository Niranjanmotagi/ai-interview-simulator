{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "color-palette",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "http-server", "color-palette", "-p", "5180", "-c-1", "--silent"],
      "port": 5180
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "-w", "apps/api"],
      "port": 4000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "-w", "apps/web"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
