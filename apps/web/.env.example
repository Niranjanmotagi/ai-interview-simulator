# Where the Next.js server proxies /api/v1/* requests (server-side rewrite).
# Local dev: the Express API. Production (Vercel): the Render API URL.
API_PROXY_TARGET=http://localhost:4000

# Optional: call the API directly from the browser instead of via the proxy.
# Leave empty to use the same-origin proxy (recommended).
NEXT_PUBLIC_API_URL=
