# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database (MongoDB Atlas in production, local/docker in dev) ---
MONGODB_URI=mongodb://localhost:27017/ai_interview_simulator

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-64+-char-random-secret-for-access-tokens-000000000000
JWT_REFRESH_SECRET=replace-with-a-64+-char-random-secret-for-refresh-tokens-00000000000
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# --- CORS (comma-separated allowlist of frontend origins) ---
CORS_ORIGIN=http://localhost:3000

# --- AI ---
# AI_PROVIDER=gemini requires GEMINI_API_KEY. AI_PROVIDER=mock runs the full app
# with a deterministic provider (no external calls) — used by tests and local demos.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_SMART_MODEL=gemini-2.5-pro

# --- Quota ---
FREE_TIER_INTERVIEWS_PER_MONTH=3

# --- Uploads (local disk; swap for S3-compatible storage in production) ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5
